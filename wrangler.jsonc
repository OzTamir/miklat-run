{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "miklat-run",
	"main": "worker/index.ts",
	"compatibility_date": "2025-09-27",
	"observability": {
		"enabled": true
	},
	"assets": {
		"not_found_handling": "single-page-application"
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "miklat-shelters",
			"database_id": "f7e1bfb8-16b3-4db8-808f-da0ed928e395"
		}
	]
}